<project name="ProyectoDAM-FAT" basedir="..">

    <target name="-post-jar" depends="">
        <property name="fatjar.dir" value="fatjar"/>
        <property name="fatjar.name" value="ProyectoDAM-FAT.jar"/>
        <mkdir dir="${fatjar.dir}"/>

        
        <jar destfile="${fatjar.dir}/temp_final.jar" filesetmanifest="skip">
            <zipgroupfileset dir="dist" includes="ProyectoDAM.jar"/>
            <zipgroupfileset dir="dist/lib" includes="*.jar"/>

            <manifest>
                <attribute name="Main-Class" value="main.Main"/>
            </manifest>
        </jar>

       
        <zip destfile="${fatjar.dir}/${fatjar.name}">
            <zipfileset src="${fatjar.dir}/temp_final.jar"
                excludes="META-INF/*.SF, META-INF/*.DSA, META-INF/*.RSA"/>
        </zip>

        <delete file="${fatjar.dir}/temp_final.jar"/>
    </target>

</project>